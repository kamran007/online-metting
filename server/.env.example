# Signaling (ws) port
PORT=4000

# Allowed browser origin(s): single, comma-separated, or "*"
CLIENT_ORIGIN=*

# --- WebRTC / ICE ---
# PUBLIC IP clients must reach this server on. On a VPS set your public IP.
# Local Docker on one machine: 127.0.0.1.
ANNOUNCED_IP=127.0.0.1
LISTEN_IP=0.0.0.0
# UDP/TCP media port range — MUST be open in the firewall and published by Docker.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100
# Workers (default = CPU cores)
# NUM_WORKERS=

# --- TLS for wss:// (or terminate TLS at nginx/Caddy in front and use ws) ---
# SSL_CERT_FILE=/certs/fullchain.pem
# SSL_KEY_FILE=/certs/privkey.pem

# --- Firebase Admin (optional: verify Google identities) ---
# FIREBASE_PROJECT_ID=online-meeting-e1545
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
