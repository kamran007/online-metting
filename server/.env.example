PORT=3001
HOST=0.0.0.0

# Allowed client origin(s): single, comma-separated list, or "*"
CLIENT_ORIGIN=http://localhost:3000

# --- LiveKit (required) ---
# LiveKit Cloud: https://cloud.livekit.io  → Project → Settings → Keys
# Self-host: run `livekit-server --dev` (prints a dev key/secret).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- Firebase Admin (optional but recommended) ---
# Verifies the client's Google ID token so identities are trusted server-side.
# Service account: Firebase console → Project settings → Service accounts → Generate key.
# Paste the private key as one line with literal \n escapes.
# FIREBASE_PROJECT_ID=online-meeting-e1545
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@online-meeting-e1545.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- HTTPS (LAN testing only) ---
# SSL_CERT_FILE=../client/certificates/localhost.pem
# SSL_KEY_FILE=../client/certificates/localhost-key.pem
